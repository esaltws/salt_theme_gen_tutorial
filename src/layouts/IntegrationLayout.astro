---
import BaseLayout from './BaseLayout.astro';

interface Integration {
  slug: string;
  title: string;
  framework: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  framework: string;
  pain: string;
  stackblitz?: string;
  integrations: Integration[];
}

const { title, description, framework, pain, stackblitz, integrations } = Astro.props;
const currentPath = Astro.url.pathname;
---

<BaseLayout title={title} description={description}>
  <div class="integration-root">
    <!-- Sidebar -->
    <aside class="integration-sidebar">
      <div class="sidebar-inner">
        <p class="sidebar-section-label">salt-theme-gen</p>
        <a href="/salt-theme-gen/" class="sidebar-pkg-link">← Package overview</a>

        <p class="sidebar-group-label">Integrations</p>
        <nav class="sidebar-nav">
          {integrations.map(item => (
            <a
              href={item.href}
              class:list={[
                'sidebar-link',
                { 'sidebar-link--active': currentPath.includes(item.slug) },
              ]}
            >
              <span class="sidebar-title">{item.title}</span>
            </a>
          ))}
        </nav>
      </div>
    </aside>

    <!-- Main content -->
    <article class="integration-article">
      <!-- Pain callout -->
      <div class="pain-callout">
        <p class="pain-callout-label">The pain this guide solves</p>
        <p class="pain-callout-text">{pain}</p>
      </div>

      <!-- Header -->
      <header class="integration-header">
        <nav class="breadcrumb">
          <a href="/">learn.esalt.net</a>
          <span>/</span>
          <a href="/salt-theme-gen/">salt-theme-gen</a>
          <span>/</span>
          <span>Integrations</span>
          <span>/</span>
          <span>{framework}</span>
        </nav>
        <h1 class="integration-title">{title}</h1>
      </header>

      <!-- MDX content -->
      <div class="integration-content">
        <slot />
      </div>

      <!-- StackBlitz CTA -->
      {stackblitz && (
        <div class="stackblitz-cta">
          <p class="stackblitz-label">Live demo</p>
          <p class="stackblitz-desc">Open this integration in StackBlitz — fully working, editable in your browser.</p>
          <a href={stackblitz} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Open in StackBlitz →
          </a>
        </div>
      )}
    </article>
  </div>
</BaseLayout>

<style>
  .integration-root {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: calc(100vh - 60px);
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Sidebar ──────────────────────────────────────────────────── */
  .integration-sidebar {
    border-right: 1px solid var(--color-border);
    position: sticky;
    top: 60px;
    height: calc(100vh - 60px);
    overflow-y: auto;
  }

  .sidebar-inner {
    padding: var(--space-xl) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .sidebar-section-label {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-primary);
    font-family: 'Fira Code', monospace;
    margin-bottom: var(--space-xs);
  }

  .sidebar-pkg-link {
    font-size: var(--text-xs);
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: var(--space-lg);
    display: block;
  }

  .sidebar-pkg-link:hover {
    color: var(--color-primary);
  }

  .sidebar-group-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-top: var(--space-md);
    margin-bottom: var(--space-xs);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    padding: 6px var(--space-sm);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--color-muted);
    font-size: var(--text-xs);
    transition: background 0.12s, color 0.12s;
  }

  .sidebar-link:hover {
    background: var(--color-surface);
    color: var(--color-text);
    text-decoration: none;
  }

  .sidebar-link--active {
    background: var(--color-surface);
    color: var(--color-primary);
    font-weight: 600;
  }

  .sidebar-title { flex: 1; }

  /* ── Article ──────────────────────────────────────────────────── */
  .integration-article {
    padding: var(--space-xxl);
    max-width: 760px;
  }

  .pain-callout {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-danger);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .pain-callout-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-danger);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .pain-callout-text {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.6;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin-bottom: var(--space-md);
  }

  .breadcrumb a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover { color: var(--color-primary); }

  .integration-title {
    font-size: var(--text-3xl);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-xxl);
    line-height: 1.15;
  }

  /* ── MDX prose ────────────────────────────────────────────────── */
  .integration-content :global(h2) {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-top: var(--space-xxl);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .integration-content :global(h3) {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .integration-content :global(p) {
    font-size: var(--text-md);
    line-height: 1.8;
    color: var(--color-muted);
    margin-bottom: var(--space-lg);
  }

  .integration-content :global(p strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .integration-content :global(ul),
  .integration-content :global(ol) {
    padding-left: var(--space-xl);
    margin-bottom: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .integration-content :global(li) {
    font-size: var(--text-md);
    line-height: 1.7;
    color: var(--color-muted);
  }

  .integration-content :global(li strong) { color: var(--color-text); }

  .integration-content :global(pre) {
    margin-bottom: var(--space-xl);
    border-radius: var(--radius-lg);
  }

  .integration-content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    background: var(--color-surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .integration-content :global(blockquote p) {
    margin-bottom: 0;
    color: var(--color-text);
    font-style: italic;
  }

  .integration-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin-bottom: var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .integration-content :global(th) {
    background: var(--color-surface);
    padding: var(--space-sm) var(--space-md);
    text-align: left;
    font-weight: 600;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
  }

  .integration-content :global(td) {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  .integration-content :global(tr:last-child td) { border-bottom: none; }

  .integration-content :global(.callout) {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .integration-content :global(.callout-tip) {
    border-left: 3px solid var(--color-success);
    background: var(--color-surface);
  }

  .integration-content :global(.callout-note) {
    border-left: 3px solid var(--color-info);
    background: var(--color-surface);
  }

  .integration-content :global(.callout-warning) {
    border-left: 3px solid var(--color-warning);
    background: var(--color-surface);
  }

  /* ── StackBlitz CTA ───────────────────────────────────────────── */
  .stackblitz-cta {
    margin-top: var(--space-xxl);
    padding: var(--space-xl) var(--space-xxl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .stackblitz-label {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-xs);
  }

  .stackblitz-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-lg);
  }

  @media (max-width: 768px) {
    .integration-root { grid-template-columns: 1fr; }
    .integration-sidebar { display: none; }
    .integration-article { padding: var(--space-xl) var(--space-lg); }
  }
</style>
