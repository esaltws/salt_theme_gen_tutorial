---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Learn esalt packages">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="badge badge-primary">Free & open source</span>
        <span class="badge">Beginner friendly</span>
      </div>
      <h1 class="hero-title">
        One theme.<br />Every platform.
      </h1>
      <p class="hero-desc">
        Learn to build production-ready design systems with esalt packages.
        From a single color — full light/dark theme, accessibility report,
        and design tokens for every framework.
      </p>
      <div class="hero-actions">
        <a href="/salt-theme-gen/guide/01-introduction/" class="btn btn-primary">
          Start learning →
        </a>
        <a href="/salt-theme-gen/" class="btn btn-outline">
          Browse packages
        </a>
      </div>
      <div class="hero-install">
        <code>npm install salt-theme-gen</code>
      </div>
    </div>
  </section>

  <!-- Pain → Solution strip -->
  <section class="pain-strip">
    <div class="container">
      <div class="pain-grid">
        {[
          {
            pain: 'Hardcoded colors everywhere',
            fix: 'One hue → full semantic token map',
          },
          {
            pain: 'Dark mode built by guessing',
            fix: 'Mathematically correct — same input, both modes',
          },
          {
            pain: 'Spacing values with no system',
            fix: 'Named scale: compact / default / relaxed / spacious',
          },
          {
            pain: 'Contrast ratios never checked',
            fix: 'AccessibilityReport built into every theme',
          },
          {
            pain: 'Web and mobile themes don\'t match',
            fix: 'salt-theme-gen + react-native-salt — designed pair',
          },
          {
            pain: 'Font sizes scattered and arbitrary',
            fix: 'FontLevel scale with semantic names',
          },
        ].map(item => (
          <div class="pain-card">
            <p class="pain-label">Before</p>
            <p class="pain-text">{item.pain}</p>
            <p class="fix-label">After</p>
            <p class="fix-text">{item.fix}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Packages -->
  <section class="packages">
    <div class="container">
      <h2 class="section-title">Packages</h2>
      <p class="section-sub">
        Each package has a full tutorial, integration guides for every major
        framework, and an AI-ready resource page.
      </p>

      <div class="pkg-grid">
        <!-- salt-theme-gen -->
        <article class="pkg-card pkg-card--active">
          <header class="pkg-card-header">
            <span class="badge badge-primary">Phase 1 — available now</span>
          </header>
          <h3 class="pkg-name">salt-theme-gen</h3>
          <p class="pkg-desc">
            OKLCH-based design system generator. One color in — full light/dark
            theme out. 17 semantic colors, 32 state colors, spacing scale,
            radius scale, font size scale, and a WCAG accessibility report.
            Zero dependencies. Platform agnostic.
          </p>
          <div class="pkg-install">
            <code>npm install salt-theme-gen</code>
          </div>
          <div class="pkg-stats">
            <span>v1.2.2</span>
            <span>MIT</span>
            <span>TypeScript</span>
            <span>428 tests</span>
          </div>
          <div class="pkg-links">
            <a href="/salt-theme-gen/guide/01-introduction/" class="btn btn-primary">
              Start tutorial →
            </a>
            <a href="/salt-theme-gen/#integrations" class="btn btn-outline">
              Integrations
            </a>
          </div>
        </article>

        <!-- react-native-salt -->
        <article class="pkg-card pkg-card--soon">
          <header class="pkg-card-header">
            <span class="badge">Phase 2 — tutorial coming soon</span>
          </header>
          <h3 class="pkg-name">@esaltws/react-native-salt</h3>
          <p class="pkg-desc">
            React Native UI kit powered by your salt-theme-gen theme. 119+
            themed components with built-in light/dark mode, font scaling,
            and zero native dependencies. Designed as a pair with salt-theme-gen.
          </p>
          <div class="pkg-install">
            <code>npm install @esaltws/react-native-salt</code>
          </div>
          <div class="pkg-stats">
            <span>v1.0.1</span>
            <span>MIT</span>
            <span>React Native + Expo</span>
          </div>
          <div class="pkg-links">
            <a href="/react-native-salt/" class="btn btn-outline">
              Learn about the pair →
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Integrations strip -->
  <section class="integrations-strip">
    <div class="container">
      <p class="strip-label">Works with every major framework and platform</p>
      <div class="strip-list">
        {[
          'React', 'Next.js', 'Vue 3', 'Nuxt 3', 'Astro', 'SvelteKit',
          'Remix', 'Angular', 'Vanilla JS', 'Tailwind CSS', 'React Native',
          'Expo', 'Flutter', 'Storybook', 'Bolt.new', 'Lovable', 'Framer',
        ].map(name => (
          <span class="strip-item">{name}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Premium teaser -->
  <section class="premium-teaser">
    <div class="container teaser-inner">
      <div>
        <h2 class="teaser-title">Interactive theme generator — coming soon</h2>
        <p class="teaser-desc">
          Pick a color, preview your full theme live, export tokens for any
          framework. Premium themes, team sharing, and Figma sync on the roadmap.
        </p>
      </div>
      <form class="teaser-form">
        <input
          type="email"
          placeholder="your@email.com"
          class="teaser-input"
          aria-label="Email address"
        />
        <button type="submit" class="btn btn-primary">Notify me</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────── */
  .hero {
    padding: var(--space-xxl) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-lg);
    max-width: 680px;
  }

  .hero-badge {
    display: flex;
    gap: var(--space-sm);
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }

  .hero-desc {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 560px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .hero-install code {
    font-size: var(--text-sm);
    padding: var(--space-sm) var(--space-md);
  }

  /* ── Pain strip ───────────────────────────────────────────────── */
  .pain-strip {
    padding: var(--space-xxl) 0;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .pain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .pain-card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .pain-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-danger);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pain-text {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
  }

  .fix-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-success);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .fix-text {
    font-size: var(--text-sm);
    color: var(--color-text);
    font-weight: 500;
  }

  /* ── Packages ─────────────────────────────────────────────────── */
  .packages {
    padding: var(--space-xxl) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .section-title {
    margin-bottom: var(--space-sm);
  }

  .section-sub {
    color: var(--color-muted);
    max-width: 560px;
    margin-bottom: var(--space-xl);
  }

  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: var(--space-lg);
  }

  .pkg-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    background: var(--color-surface);
  }

  .pkg-card--active {
    border-color: var(--color-primary);
    background: var(--surface-card);
  }

  .pkg-card--soon {
    opacity: 0.75;
  }

  .pkg-card-header {
    display: flex;
    gap: var(--space-sm);
  }

  .pkg-name {
    font-size: var(--text-xl);
    font-weight: 700;
    font-family: 'Fira Code', monospace;
    color: var(--color-text);
  }

  .pkg-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.7;
  }

  .pkg-install code {
    font-size: var(--text-xs);
    display: block;
    padding: var(--space-sm) var(--space-md);
  }

  .pkg-stats {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .pkg-stats span {
    font-size: var(--text-xs);
    color: var(--color-muted);
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.5em;
  }

  .pkg-links {
    display: flex;
    gap: var(--space-sm);
    margin-top: auto;
    padding-top: var(--space-sm);
  }

  /* ── Integrations strip ───────────────────────────────────────── */
  .integrations-strip {
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .strip-label {
    font-size: var(--text-xs);
    color: var(--color-muted);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    margin-bottom: var(--space-lg);
  }

  .strip-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    justify-content: center;
  }

  .strip-item {
    font-size: var(--text-sm);
    color: var(--color-muted);
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xs) var(--space-md);
  }

  /* ── Premium teaser ───────────────────────────────────────────── */
  .premium-teaser {
    padding: var(--space-xxl) 0;
    background: var(--color-primary);
  }

  .teaser-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .teaser-title {
    color: var(--color-on-primary);
    font-size: var(--text-xxl);
    margin-bottom: var(--space-sm);
  }

  .teaser-desc {
    color: var(--color-on-primary);
    opacity: 0.85;
    font-size: var(--text-sm);
    max-width: 480px;
    line-height: 1.7;
  }

  .teaser-form {
    display: flex;
    gap: var(--space-sm);
    flex-shrink: 0;
  }

  .teaser-input {
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    border: none;
    font-size: var(--text-sm);
    min-width: 220px;
    background: var(--color-on-primary);
    color: var(--color-primary);
  }

  .teaser-input::placeholder {
    color: var(--color-muted);
  }

  .teaser-form .btn-primary {
    background: var(--color-text);
    color: var(--color-background);
  }
</style>
