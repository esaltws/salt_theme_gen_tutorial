---
import { buildCss } from '../lib/theme';
const css = buildCss();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>salt-theme-gen — Astro</title>
  <style set:html={css} />
  <script is:inline>
    try {
      var t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    } catch (e) {}
  </script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: var(--color-background); color: var(--color-text); min-height: 100vh; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
